{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "rootDir": "./",
    "outDir": "../dist/api"
  },
  "include": ["**/*"]
}
