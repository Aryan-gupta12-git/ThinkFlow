{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "rootDir": "../",
    "outDir": "../dist/api"
  },
  "include": ["index.ts", "../backend/src/**/*"]
}
