{
  "name": "thinkflow-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Production-ready backend for ThinkFlow communication trainer, powered by Google Gemini 2.5 Flash",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/server.js",
    "dev": "nodemon --watch ../api --watch .env -e ts,env --exec ts-node src/server.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "groq-sdk": "^1.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  }
}
